.hero {
  background: linear-gradient(135deg, #082f49 0%, #0f766e 58%, #34d399 100%);
  color: #ffffff;
}

.hero-top,
.saved-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
  margin-bottom: 24rpx;
}

.parking-map {
  width: 100%;
  height: 560rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.mode-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.mode-btn {
  flex: 1;
  background: #e2e8f0;
  color: #0f172a;
}

.mode-btn.active {
  background: #0f172a;
  color: #ffffff;
}

.saved-card {
  border: 2rpx solid #cbd5e1;
}

.saved-actions {
  margin-top: 22rpx;
}

.stat-grid {
  margin-bottom: 22rpx;
}

.cloud-pill {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: right;
}
