.find-hero {
  background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 52%, #60a5fa 100%);
  color: #ffffff;
}

.find-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.find-subtitle {
  margin-top: 10rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.84);
}

.guide-step {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-bottom: 22rpx;
}

.guide-index {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 50%;
  text-align: center;
  background: #dbeafe;
  color: #1d4ed8;
  font-weight: 700;
  font-size: 24rpx;
  flex-shrink: 0;
}

.guide-content {
  flex: 1;
}

.guide-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.guide-desc {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #475569;
}

.small {
  font-size: 24rpx;
}
