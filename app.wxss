page {
  background: #f3f4f6;
  color: #111827;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.muted {
  color: #64748b;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #e2e8f0;
  color: #334155;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.btn-primary,
.btn-secondary,
.btn-danger,
.btn-ghost {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin: 0;
}

.btn-primary {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
  color: #ffffff;
}

.btn-secondary {
  background: #0f172a;
  color: #ffffff;
}

.btn-danger {
  background: #fee2e2;
  color: #b91c1c;
}

.btn-ghost {
  background: #e2e8f0;
  color: #0f172a;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
}

.input,
.textarea,
.picker {
  width: 100%;
  background: #f8fafc;
  border: 2rpx solid #dbe4ee;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #0f172a;
}

.textarea {
  min-height: 168rpx;
}

.picker {
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.meta-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-item {
  font-size: 27rpx;
  color: #1f2937;
}

.hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.photo-card {
  position: relative;
  border-radius: 22rpx;
  overflow: hidden;
  background: #e2e8f0;
}

.photo-image {
  width: 100%;
  height: 200rpx;
  display: block;
}

.photo-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 22rpx;
}

.photo-remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  color: #b91c1c;
  text-align: center;
  font-size: 28rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-card {
  padding: 18rpx;
  border-radius: 20rpx;
  background: #eff6ff;
}

.stat-label {
  font-size: 22rpx;
  color: #64748b;
}

.stat-value {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}
